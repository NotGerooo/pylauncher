{
    "git.autofetch": true,
    "git.enableSmartCommit": true,
    "git.postCommitCommand": "push",
    "gitdoc.enabled": true,
    "gitdoc.autoCommitDelay": 3000,
    "git.decorations.enabled": false,
    "gitdoc.excludedGlobs": [
         "**/build/**",
         "**/dist/**",
         "**/logs/**",
         "**/data/**",
         "**/*.spec"         // excluye PyLauncher.spec
]
}